# GitHub OAuth (required)
NUXT_OAUTH_GITHUB_CLIENT_ID=
NUXT_OAUTH_GITHUB_CLIENT_SECRET=
NUXT_SESSION_PASSWORD=

# Storage driver for user settings
# Dev: no env needed, defaults to fs (.data/user-settings/)
# Prod: set these in your hosting environment (e.g. Vercel)
# STORAGE_DRIVER=upstash
# STORAGE_URL=https://your-upstash-url.upstash.io
# STORAGE_TOKEN=your-upstash-token

# Cloudflare R2 (image uploads, optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=flumen-uploads
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
